# Copia a ".env" y rellena. El .env NO se sube al repo.
# Dónde sacar cada credencial → ver CREDENCIALES.md

# ── Google (audits: Places API New + PageSpeed) ──
# Ya en uso. Key del proyecto Google Cloud de MTRYX, restringida a esas 2 APIs.
GOOGLE_MAPS_API_KEY=
PAGESPEED_API_KEY=            # opcional; si vacío usa GOOGLE_MAPS_API_KEY

# ── DataForSEO (Map Pack REAL + listados con teléfono/web) ──
# Auth HTTP Basic. Viven como env vars en la torre de Jorge (virtualenv seo-toolkit).
# PEDIR A JORGE. Sin esto, el audit usa la posición aproximada de Places.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Brevo (envío de email) ──
# En Supabase agent_config -> integration_credentials_brevo (api_key, smtp_*).
# Remitentes mtryx.com: jorge@ jordi@ hola@ newsletter@ system@
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hola@mtryx.com
BREVO_SENDER_NAME=MTRYX

# ── Apify (scraping de emails donde Google no los da) ──
# En Supabase agent_config -> integration_credentials_apify. (Integración pendiente.)
APIFY_TOKEN=
